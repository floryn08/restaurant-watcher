GOOGLE_MAPS_API_KEY=

# Bounding box coordinates (SW = south-west corner, NE = north-east corner)
SW_LAT=45.638
SW_LNG=25.584
NE_LAT=45.646
NE_LNG=25.597

# Number of grid cells per axis (higher = finer scan, more API calls)
GRID_SIZE=4

# Path for the persisted registry JSON (default: /data/... for Kubernetes)
DATA_FILE=./city_center_registry.json

# Ollama — used to generate the Discord announcement
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Discord webhook URL — leave empty to skip notifications
DISCORD_WEBHOOK_URL=